{
  "name": "project-helix",
  "productName": "PRISM",
  "version": "1.5.1",
  "description": "Clinical decision support desktop app for pancreatic cancer care pathways (YSTE project)",
  "author": "Cillian McCarthy",
  "main": "dist/main/main.js",
  "build": {
    "appId": "com.projecthelix.prism",
    "productName": "PRISM",
    "artifactName": "PRISM-Setup-${version}.${ext}",
    "win": {
      "executableName": "PRISM"
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always",
    "release": "npm run build && npm run publish",
    "release:patch": "npm version patch && npm run release",
    "release:minor": "npm version minor && npm run release",
    "release:major": "npm version major && npm run release",
    "postversion": "git push && git push --tags"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "electron-updater": "^6.8.9",
    "papaparse": "^5.5.4",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.0"
  }
}
